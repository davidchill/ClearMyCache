<!-- Theme toggle: System / Light / Dark -->
<div
  class="flex items-center bg-slate-100 dark:bg-slate-800 rounded-xl p-1 gap-0.5"
  role="group"
  aria-label="Choose color theme"
>
  <button
    data-theme="system"
    class="theme-btn flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs font-semibold transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1 dark:focus:ring-offset-slate-800"
    aria-pressed="false"
    title="Use system theme"
  >
    <!-- Monitor icon -->
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="14" x="2" y="3" rx="2"/><path d="M8 21h8m-4-4v4"/></svg>
    <span class="hidden sm:inline">System</span>
  </button>

  <button
    data-theme="light"
    class="theme-btn flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs font-semibold transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1 dark:focus:ring-offset-slate-800"
    aria-pressed="false"
    title="Light mode"
  >
    <!-- Sun icon -->
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
    <span class="hidden sm:inline">Light</span>
  </button>

  <button
    data-theme="dark"
    class="theme-btn flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs font-semibold transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1 dark:focus:ring-offset-slate-800"
    aria-pressed="false"
    title="Dark mode"
  >
    <!-- Moon icon -->
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
    <span class="hidden sm:inline">Dark</span>
  </button>
</div>

<script>
  const STORAGE_KEY = 'theme';

  function getStored(): string {
    return localStorage.getItem(STORAGE_KEY) ?? 'system';
  }

  function applyTheme(theme: string) {
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const isDark = theme === 'dark' || (theme === 'system' && prefersDark);
    document.documentElement.classList.toggle('dark', isDark);
  }

  function updateButtons(active: string) {
    document.querySelectorAll<HTMLButtonElement>('.theme-btn').forEach(btn => {
      const isActive = btn.dataset.theme === active;
      btn.setAttribute('aria-pressed', String(isActive));
      if (isActive) {
        btn.classList.add('bg-white', 'dark:bg-slate-700', 'shadow-sm', 'text-blue-600', 'dark:text-blue-400');
        btn.classList.remove('text-slate-500', 'dark:text-slate-400', 'hover:text-slate-700', 'dark:hover:text-slate-200');
      } else {
        btn.classList.remove('bg-white', 'dark:bg-slate-700', 'shadow-sm', 'text-blue-600', 'dark:text-blue-400');
        btn.classList.add('text-slate-500', 'dark:text-slate-400', 'hover:text-slate-700', 'dark:hover:text-slate-200');
      }
    });
  }

  function setTheme(theme: string) {
    localStorage.setItem(STORAGE_KEY, theme);
    applyTheme(theme);
    updateButtons(theme);
  }

  // Init
  const current = getStored();
  updateButtons(current);

  // Button clicks
  document.querySelectorAll<HTMLButtonElement>('.theme-btn').forEach(btn => {
    btn.addEventListener('click', () => setTheme(btn.dataset.theme!));
  });

  // Respond to OS preference changes when on "system"
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (getStored() === 'system') applyTheme('system');
  });
</script>
