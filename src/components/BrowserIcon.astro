---
interface Props {
  browser: string;
  size?: number;
}
const { browser, size = 32 } = Astro.props;
---

{browser === 'chrome' && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <circle cx="16" cy="16" r="16" fill="#fff"/>
    <!-- Chrome ring -->
    <path d="M16 6a10 10 0 0 1 8.66 5H16a5 5 0 0 0-4.33 2.5L9.02 9.17A10 10 0 0 1 16 6Z" fill="#EA4335"/>
    <path d="M26 16a10 10 0 0 1-5 8.66l-3.5-6.06A5 5 0 0 0 21 16H26Z" fill="#34A853"/>
    <path d="M6 16a10 10 0 0 1 3.02-7.17l3.5 6.06A5 5 0 0 0 11 16a5 5 0 0 0 2.5 4.33L9.9 26.54A10 10 0 0 1 6 16Z" fill="#FBBC04"/>
    <path d="M16 21a5 5 0 0 0 4.5-2.83L24 25a10 10 0 0 1-14.1 1.54L13.4 20.5A5 5 0 0 0 16 21Z" fill="#34A853"/>
    <circle cx="16" cy="16" r="4" fill="white"/>
    <circle cx="16" cy="16" r="3" fill="#1A73E8"/>
  </svg>
)}

{browser === 'firefox' && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <circle cx="16" cy="16" r="16" fill="#FF7139"/>
    <circle cx="16" cy="16" r="8" fill="#FFA940"/>
    <circle cx="16" cy="16" r="4" fill="#FF4500"/>
    <path d="M16 8C11.58 8 8 11.58 8 16s3.58 8 8 8" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
)}

{browser === 'safari' && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <circle cx="16" cy="16" r="16" fill="url(#safari-grad)"/>
    <circle cx="16" cy="16" r="11" stroke="white" stroke-width="1.5" stroke-opacity="0.6"/>
    <!-- Compass needle N/S -->
    <path d="M16 7v2M16 23v2M7 16h2M23 16h2" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-opacity="0.7"/>
    <!-- Needle -->
    <path d="M16 16L20 10" stroke="#FF3B30" stroke-width="2" stroke-linecap="round"/>
    <path d="M16 16L12 22" stroke="white" stroke-width="2" stroke-linecap="round"/>
    <circle cx="16" cy="16" r="2" fill="white"/>
    <defs>
      <linearGradient id="safari-grad" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
        <stop stop-color="#1B78E6"/>
        <stop offset="1" stop-color="#0055D4"/>
      </linearGradient>
    </defs>
  </svg>
)}

{browser === 'edge' && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <circle cx="16" cy="16" r="16" fill="url(#edge-grad)"/>
    <path d="M22 12c0-3.31-2.69-6-6-6a6 6 0 0 0-6 6c0 2.76 1.86 5.09 4.41 5.79C12.7 18.62 11 20.66 11 23c0 1.1.9 2 2 2h8" stroke="white" stroke-width="2" stroke-linecap="round"/>
    <defs>
      <linearGradient id="edge-grad" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
        <stop stop-color="#0078D7"/>
        <stop offset="1" stop-color="#00B4FF"/>
      </linearGradient>
    </defs>
  </svg>
)}

{browser === 'brave' && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <circle cx="16" cy="16" r="16" fill="#FB542B"/>
    <path d="M16 6L22 10V18C22 21.31 19.31 24 16 24C12.69 24 10 21.31 10 18V10L16 6Z" fill="white" fill-opacity="0.9"/>
    <path d="M16 9L19.5 11.25V17.5C19.5 19.71 17.93 21.5 16 21.5C14.07 21.5 12.5 19.71 12.5 17.5V11.25L16 9Z" fill="#FB542B"/>
  </svg>
)}

{browser === 'opera' && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <circle cx="16" cy="16" r="16" fill="#FF1B2D"/>
    <ellipse cx="16" cy="16" rx="6" ry="9" stroke="white" stroke-width="2.5"/>
  </svg>
)}

{browser === 'samsung' && (
  <svg width={size} height={size} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <circle cx="16" cy="16" r="16" fill="#1428A0"/>
    <text x="16" y="21" text-anchor="middle" font-size="14" font-weight="700" fill="white" font-family="sans-serif">S</text>
  </svg>
)}
