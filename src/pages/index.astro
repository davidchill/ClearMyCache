---
import Layout from '../layouts/Layout.astro';
import BrowserIcon from '../components/BrowserIcon.astro';
import PlatformIcon from '../components/PlatformIcon.astro';
import { BROWSERS, PLATFORMS, VALID_COMBOS } from '../data/guides';
---

<Layout title="ClearMyCache.io — Clear your browser cache in seconds">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-blue-600 via-blue-700 to-blue-900 text-white">
    <!-- Subtle dot grid -->
    <div
      class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 28px 28px;"
      aria-hidden="true"
    ></div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 pt-10 pb-12 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight mb-3">
        Clear your cache &amp;<br class="hidden sm:block" /> cookies in seconds
      </h1>
      <p class="text-blue-100 text-lg sm:text-xl max-w-2xl mx-auto mb-6">
        Pick your browser and device below — we'll walk you through it step by step,
        no tech knowledge needed.
      </p>

      <div class="flex flex-col items-center gap-6">
        <!-- Detection badge (shown by JS) -->
        <div
          id="detection-badge"
          class="hidden items-center gap-2 bg-white/15 backdrop-blur-sm border border-white/25 rounded-full px-4 py-2 text-sm font-medium"
        >
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
          <span id="detection-text">Detecting your browser…</span>
        </div>

        <!-- Auto-detect CTA (shown by JS when detection succeeds) -->
        <a
          id="auto-cta"
          href="#selector"
          class="hidden items-center gap-2 bg-white text-blue-700 font-bold text-lg px-8 py-4 rounded-2xl shadow-lg hover:shadow-xl hover:scale-105 active:scale-100 transition-all duration-150"
        >
          Show me how
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Selector -->
  <section id="selector" class="max-w-5xl mx-auto px-4 sm:px-6 py-8 sm:py-10">
    <div class="text-center mb-6">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-slate-100 mb-2">
        Choose your browser &amp; device
      </h2>
      <p class="text-slate-500 dark:text-slate-400">We'll show you exactly what to tap or click.</p>
    </div>

    <!-- Platform grid -->
    <div class="mb-6">
      <p class="text-[15px] font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-300 mb-3 text-center">Device / OS</p>
      <div class="grid grid-cols-3 sm:grid-cols-5 gap-3" id="platform-grid" role="group" aria-label="Select your device or operating system">
        {PLATFORMS.map(p => (
          <button
            data-platform={p.id}
            class="platform-btn flex flex-col items-center gap-2 p-3 sm:p-4 rounded-2xl border-2 border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 hover:border-blue-400 dark:hover:border-blue-500 hover:bg-blue-50 dark:hover:bg-blue-950/40 transition-all duration-150 cursor-pointer group focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-slate-950"
            aria-pressed="false"
          >
            <PlatformIcon platform={p.id} size={28} />
            <span class="text-xs font-medium text-slate-700 dark:text-slate-300 text-center group-hover:text-blue-700 dark:group-hover:text-blue-400">
              {p.name}
            </span>
          </button>
        ))}
      </div>
    </div>

    <!-- Browser grid (hidden until device is selected) -->
    <div class="mb-6 hidden" id="browser-section">
      <p class="text-[15px] font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-300 mb-3 text-center">Browser</p>
      <div class="flex flex-wrap justify-center gap-2" id="browser-grid" role="group" aria-label="Select your browser">
        {BROWSERS.map(b => (
          <button
            data-browser={b.id}
            class="browser-btn flex flex-col items-center gap-1.5 p-2 sm:p-3 rounded-2xl border-2 border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 hover:border-blue-400 dark:hover:border-blue-500 hover:bg-blue-50 dark:hover:bg-blue-950/40 transition-all duration-150 cursor-pointer group focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-slate-950 w-[min(8rem,calc(50%-0.25rem))] sm:w-28"
            aria-pressed="false"
          >
            <BrowserIcon browser={b.id} size={28} />
            <span class="text-xs font-medium text-slate-700 dark:text-slate-300 text-center leading-tight group-hover:text-blue-700 dark:group-hover:text-blue-400">
              {b.name}
            </span>
          </button>
        ))}
      </div>
    </div>

    <!-- Incompatible notice -->
    <div id="combo-error" class="hidden mb-4 items-center gap-3 bg-amber-50 dark:bg-amber-950/40 border border-amber-200 dark:border-amber-800 text-amber-800 dark:text-amber-300 rounded-2xl p-4 text-sm font-medium">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
      That combination isn't available — try a different browser or device.
    </div>

    <!-- Go button -->
    <div class="text-center">
      <button
        id="go-btn"
        disabled
        class="inline-flex items-center gap-2 bg-blue-600 text-white font-bold text-lg px-10 py-4 rounded-2xl shadow-md hover:bg-blue-700 hover:shadow-lg hover:scale-105 active:scale-100 transition-all duration-150 disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:scale-100 disabled:hover:shadow-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-slate-950"
      >
        Show me how
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </button>
    </div>
  </section>

  <!-- Why clear cache? -->
  <section class="bg-white dark:bg-slate-900 border-y border-slate-100 dark:border-slate-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 sm:py-10 grid sm:grid-cols-3 gap-6 text-center">
      <div class="flex flex-col items-center gap-3">
        <div class="w-12 h-12 rounded-2xl bg-blue-100 dark:bg-blue-950 flex items-center justify-center text-blue-600 dark:text-blue-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </div>
        <h3 class="font-bold text-slate-900 dark:text-slate-100">Takes 60 seconds</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">A handful of simple steps and you're done — no typing, no tech skills required.</p>
      </div>
      <div class="flex flex-col items-center gap-3">
        <div class="w-12 h-12 rounded-2xl bg-emerald-100 dark:bg-emerald-950 flex items-center justify-center text-emerald-600 dark:text-emerald-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="font-bold text-slate-900 dark:text-slate-100">Safe &amp; private</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">This site never asks for your data. We just show you the steps — you do everything on your own device.</p>
      </div>
      <div class="flex flex-col items-center gap-3">
        <div class="w-12 h-12 rounded-2xl bg-purple-100 dark:bg-purple-950 flex items-center justify-center text-purple-600 dark:text-purple-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>
        </div>
        <h3 class="font-bold text-slate-900 dark:text-slate-100">Fixes common issues</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">Pages not loading, old content showing, login problems — clearing your cache often fixes all of these.</p>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ VALID_COMBOS }}>
  let selectedBrowser = null;
  let selectedPlatform = null;

  const validSet = new Set(VALID_COMBOS.map(([b, p]) => `${b}|${p}`));

  function isValid(b, p) {
    return Boolean(b && p && validSet.has(`${b}|${p}`));
  }

  function updateUI() {
    const comboError = document.getElementById('combo-error');
    const goBtn = document.getElementById('go-btn');
    const invalid = selectedBrowser && selectedPlatform && !isValid(selectedBrowser, selectedPlatform);

    comboError.style.display = invalid ? 'flex' : 'none';
    goBtn.disabled = !isValid(selectedBrowser, selectedPlatform);
  }

  document.querySelectorAll('.browser-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      selectedBrowser = btn.dataset.browser;
      document.querySelectorAll('.browser-btn').forEach(b => {
        const active = b.dataset.browser === selectedBrowser;
        b.classList.toggle('border-blue-500', active);
        b.classList.toggle('bg-blue-50', active);
        b.classList.toggle('border-slate-200', !active);
        b.setAttribute('aria-pressed', String(active));
      });
      updateUI();
    });
  });

  document.querySelectorAll('.platform-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const clicked = btn.dataset.platform;

      if (selectedPlatform === clicked) {
        // Deselect: toggle off
        selectedPlatform = null;
        selectedBrowser = null;

        document.querySelectorAll('.platform-btn').forEach(b => {
          b.classList.remove('border-blue-500', 'bg-blue-50');
          b.classList.add('border-slate-200');
          b.setAttribute('aria-pressed', 'false');
        });

        document.querySelectorAll('.browser-btn').forEach(b => {
          b.classList.remove('hidden', 'border-blue-500', 'bg-blue-50');
          b.classList.add('border-slate-200');
          b.setAttribute('aria-pressed', 'false');
        });

        document.getElementById('browser-section').classList.add('hidden');
      } else {
        // Select new platform
        selectedPlatform = clicked;
        selectedBrowser = null;

        document.querySelectorAll('.platform-btn').forEach(b => {
          const active = b.dataset.platform === selectedPlatform;
          b.classList.toggle('border-blue-500', active);
          b.classList.toggle('bg-blue-50', active);
          b.classList.toggle('border-slate-200', !active);
          b.setAttribute('aria-pressed', String(active));
        });

        document.querySelectorAll('.browser-btn').forEach(b => {
          const compatible = validSet.has(`${b.dataset.browser}|${selectedPlatform}`);
          b.classList.toggle('hidden', !compatible);
          b.classList.remove('border-blue-500', 'bg-blue-50');
          b.classList.add('border-slate-200');
          b.setAttribute('aria-pressed', 'false');
        });

        document.getElementById('browser-section').classList.remove('hidden');
      }

      updateUI();
    });
  });

  document.getElementById('go-btn').addEventListener('click', () => {
    if (isValid(selectedBrowser, selectedPlatform)) {
      window.location.href = `/${selectedBrowser}/${selectedPlatform}`;
    }
  });

  // ── Auto-detection ──────────────────────────────────────────────────────────
  (function detect() {
    const ua = navigator.userAgent;

    let os = 'windows';
    if (/iPad/.test(ua) || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1)) os = 'ipad';
    else if (/iPhone/.test(ua)) os = 'iphone';
    else if (/Android/.test(ua)) os = 'android';
    else if (/Mac/.test(navigator.platform)) os = 'macos';

    let browser = 'chrome';
    if (/SamsungBrowser/.test(ua)) browser = 'samsung';
    else if (/Edg\//.test(ua)) browser = 'edge';
    else if (/OPR\/|Opera/.test(ua)) browser = 'opera';
    else if (window.navigator.brave) browser = 'brave';
    else if (/Firefox/.test(ua)) browser = 'firefox';
    else if (/Safari/.test(ua) && !/Chrome/.test(ua)) browser = 'safari';

    if (!validSet.has(`${browser}|${os}`)) return;

    const browserBtn = document.querySelector(`[data-browser="${browser}"]`);
    const platformBtn = document.querySelector(`[data-platform="${os}"]`);
    if (platformBtn) platformBtn.click();
    if (browserBtn) browserBtn.click();

    const BROWSER_NAMES = { chrome: 'Chrome', firefox: 'Firefox', safari: 'Safari', edge: 'Edge', brave: 'Brave', opera: 'Opera', samsung: 'Samsung Internet' };
    const OS_NAMES = { windows: 'Windows', macos: 'macOS', iphone: 'iPhone', ipad: 'iPad', android: 'Android' };
    document.getElementById('detection-text').textContent = `Detected: ${BROWSER_NAMES[browser]} on ${OS_NAMES[os]}`;
    const badge = document.getElementById('detection-badge');
    badge.style.display = 'inline-flex';
    const cta = document.getElementById('auto-cta');
    cta.href = `/${browser}/${os}`;
    cta.style.display = 'inline-flex';
  })();
</script>
