---
import Layout from '../../layouts/Layout.astro';
import BrowserIcon from '../../components/BrowserIcon.astro';
import PlatformIcon from '../../components/PlatformIcon.astro';
import { VALID_COMBOS, getGuide, getBrowserInfo, getPlatformInfo } from '../../data/guides';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return VALID_COMBOS.map(([browser, os]) => ({
    params: { browser, os },
  }));
};

const { browser, os } = Astro.params;
const guide = getGuide(browser, os);
const browserInfo = getBrowserInfo(browser);
const platformInfo = getPlatformInfo(os);

if (!guide || !browserInfo || !platformInfo) {
  return Astro.redirect('/');
}

const totalSteps = guide.steps.length;
const pageTitle = `How to clear ${guide.browserName} cache on ${guide.osName} — ClearMyCache.io`;
const pageDesc = `Step-by-step guide to clear ${guide.browserName} cookies and cache on ${guide.osName}. Simple instructions with screenshots.`;
---

<Layout title={pageTitle} description={pageDesc}>
  <!-- Page header — intentionally dark in both themes (high contrast, brand feel) -->
  <div class="bg-gradient-to-br from-slate-900 to-slate-800 text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-slate-400 hover:text-white text-sm font-medium mb-6 transition-colors group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
        Back
      </a>

      <div class="flex items-center gap-4 mb-4">
        <div class="w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0">
          <BrowserIcon browser={guide.browser} size={36} />
        </div>
        <div>
          <h1 class="text-2xl sm:text-3xl font-extrabold leading-tight">
            Clear {guide.browserName} cache
          </h1>
          <p class="text-slate-400 mt-0.5 flex items-center gap-1.5">
            <PlatformIcon platform={os} size={18} />
            {guide.osName} &nbsp;·&nbsp; {totalSteps} steps
          </p>
        </div>
      </div>

      <p class="text-slate-300 text-sm sm:text-base leading-relaxed max-w-xl">
        {guide.intro}
      </p>
    </div>
  </div>

  <!-- Progress bar (sticky) -->
  <div class="sticky top-16 z-40 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-700 shadow-sm" id="progress-bar-container">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-2 flex items-center gap-3">
      <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 whitespace-nowrap" id="progress-label">Step 1 of {totalSteps}</span>
      <div class="flex-1 bg-slate-100 dark:bg-slate-700 rounded-full h-2 overflow-hidden">
        <div
          id="progress-fill"
          class="h-full bg-blue-500 rounded-full transition-all duration-500"
          style="width: 0%"
        ></div>
      </div>
      <span class="text-xs font-semibold text-slate-400 dark:text-slate-500" id="progress-pct">0%</span>
    </div>
  </div>

  <!-- Steps -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10 space-y-8" id="steps-container">
    {guide.steps.map((step, i) => {
      const stepNum = i + 1;
      const imgPath = step.image ? `/screenshots/${step.image}` : null;
      return (
        <div
          class="step-card bg-white dark:bg-slate-800 rounded-3xl border border-slate-200 dark:border-slate-700 overflow-hidden shadow-sm hover:shadow-md dark:hover:shadow-slate-900 transition-shadow duration-200"
          data-step={stepNum}
        >
          <!-- Step header -->
          <div class="flex items-start gap-4 p-5 sm:p-6">
            <div
              class="w-9 h-9 rounded-full flex-shrink-0 flex items-center justify-center font-bold text-sm text-white"
              style={`background-color: ${browserInfo.color}`}
            >
              {stepNum}
            </div>
            <div class="flex-1 min-w-0">
              <h2 class="font-bold text-slate-900 dark:text-slate-100 text-base sm:text-lg leading-snug">
                {step.instruction}
              </h2>
              {step.detail && (
                <p class="text-slate-500 dark:text-slate-400 text-sm sm:text-base mt-1 leading-relaxed">
                  {step.detail}
                </p>
              )}
              {step.shortcut && (
                <div class="mt-3 inline-flex items-center gap-2 bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded-lg px-3 py-1.5 text-xs font-medium">
                  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="M6 8h.001M10 8h.001M14 8h.001M18 8h.001M8 12h.001M12 12h.001M16 12h.001M7 16h10"/></svg>
                  Shortcut: <kbd class="font-mono font-semibold">{step.shortcut}</kbd>
                </div>
              )}
            </div>
          </div>

          <!-- Screenshot -->
          {imgPath && (
            <div class="border-t border-slate-100 dark:border-slate-700 bg-slate-50 dark:bg-slate-900 px-5 sm:px-6 pb-5 sm:pb-6 pt-4">
              <img
                src={imgPath}
                alt={`Step ${stepNum}: ${step.instruction}`}
                class="w-full rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm"
                loading="lazy"
                decoding="async"
                onerror="this.parentElement.style.display='none'"
              />
            </div>
          )}
        </div>
      );
    })}

    <!-- Done card -->
    <div class="bg-gradient-to-br from-emerald-500 to-emerald-600 text-white rounded-3xl p-6 sm:p-8 text-center shadow-lg" id="done-card">
      <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <h2 class="text-2xl font-extrabold mb-2">All done!</h2>
      <p class="text-emerald-100 mb-6 text-sm sm:text-base">
        Your cache and cookies have been cleared. Reload the page that was giving you trouble and it should be working now.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 bg-white text-emerald-700 font-bold px-6 py-3 rounded-2xl hover:scale-105 active:scale-100 transition-transform"
      >
        Back to home
      </a>
    </div>
  </div>

  <!-- Quick-reference accordion -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 pb-14">
    <details class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl overflow-hidden group">
      <summary class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer font-semibold text-slate-700 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors list-none">
        All steps at a glance
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 transition-transform group-open:rotate-180" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
      </summary>
      <ol class="px-5 pb-5 space-y-2">
        {guide.steps.map((step, i) => (
          <li class="flex items-start gap-3 text-sm">
            <span
              class="w-5 h-5 rounded-full flex-shrink-0 flex items-center justify-center text-white text-xs font-bold mt-0.5"
              style={`background-color: ${browserInfo.color}`}
            >
              {i + 1}
            </span>
            <span class="text-slate-700 dark:text-slate-300">{step.instruction}</span>
          </li>
        ))}
      </ol>
    </details>
  </div>
</Layout>

<script define:vars={{ totalSteps }}>
  // Scroll-based progress tracking
  const stepCards = document.querySelectorAll('.step-card');
  const progressFill = document.getElementById('progress-fill');
  const progressLabel = document.getElementById('progress-label');
  const progressPct = document.getElementById('progress-pct');

  function updateProgress() {
    let lastVisible = 0;
    stepCards.forEach((card, i) => {
      const rect = card.getBoundingClientRect();
      if (rect.top < window.innerHeight * 0.75) lastVisible = i + 1;
    });
    const pct = totalSteps > 0 ? Math.round((lastVisible / totalSteps) * 100) : 0;
    progressFill.style.width = `${pct}%`;
    progressLabel.textContent = lastVisible > 0 ? `Step ${lastVisible} of ${totalSteps}` : `${totalSteps} steps`;
    progressPct.textContent = `${pct}%`;
  }

  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();
</script>
