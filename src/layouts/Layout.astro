---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Step-by-step instructions to clear your browser cache and cookies — fast, friendly, and jargon-free.',
  ogImage = '/og.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://clearmycache.io');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Before-paint theme script: prevents flash of wrong theme -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || ((!stored || stored === 'system') && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-100 transition-colors duration-200">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-700">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-2.5 group flex-shrink-0" aria-label="ClearMyCache home">
          <!-- Logo mark -->
          <div class="w-9 h-9 flex-shrink-0">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect width="36" height="36" rx="10" fill="#2563EB"/>
              <path
                d="M18 8C12.477 8 8 12.477 8 18C8 23.523 12.477 28 18 28"
                stroke="white" stroke-width="2.5" stroke-linecap="round"
              />
              <path
                d="M18 8C23.523 8 28 12.477 28 18C28 23.523 23.523 28 18 28"
                stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-opacity="0.4"
              />
              <path
                d="M18 4L18 12L22 8L18 4Z"
                fill="white"
              />
              <circle cx="18" cy="18" r="3.5" fill="white"/>
            </svg>
          </div>
          <!-- Wordmark -->
          <span class="text-slate-900 dark:text-white font-bold text-lg leading-none">
            clear<span class="text-blue-600 dark:text-blue-400">my</span>cache
            <span class="text-slate-400 dark:text-slate-500 font-normal">.io</span>
          </span>
        </a>

        <nav class="flex items-center gap-2">
          <a
            href="/"
            class="text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-blue-600 dark:hover:text-blue-400 px-3 py-1.5 rounded-lg hover:bg-blue-50 dark:hover:bg-blue-950 transition-colors"
          >
            Home
          </a>
          <ThemeToggle />
        </nav>
      </div>
    </header>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-16 border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-500 dark:text-slate-400">
        <p>
          &copy; {new Date().getFullYear()}
          <strong class="text-slate-700 dark:text-slate-200">clearmycache.io</strong> — Free to use, no sign-up needed.
        </p>
        <p class="text-xs text-slate-400 dark:text-slate-500">
          Not affiliated with any browser maker.
        </p>
      </div>
    </footer>
  </body>
</html>
